<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="220.0" prefWidth="240.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.tvz.carservicemanagementsystem.controller.UserCardItemController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Circle fill="#3A6EA5" radius="30.0" stroke="TRANSPARENT" />

        <VBox alignment="CENTER" spacing="2.0">
            <children>
                <Label fx:id="userNameLabel" style="-fx-text-fill: #004E98; -fx-font-weight: bold; -fx-font-size: 16px;" />
                <Label fx:id="userRoleLabel" style="-fx-background-color: #EBEBEB; -fx-background-radius: 10; -fx-padding: 2 10 2 10; -fx-text-fill: #808080;" text="MECHANIC">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <Label fx:id="userEmailLabel" style="-fx-text-fill: #808080;" />

        <HBox alignment="CENTER" spacing="10.0">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
            <children>
                <Button mnemonicParsing="false" fx:id="editButton" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #3A6EA5; -fx-text-fill: white; -fx-background-radius: 5;" text="Edit">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
                <Button mnemonicParsing="false" fx:id="deleteButton" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-background-radius: 5;" text="Delete">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>